{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch (SEGGER JLink)",
            "request": "launch",
            "type": "cortex-debug",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            },
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceFolder}/build/Debug/bm_lesson_canopen.elf",
            // "svdFile": "${workspaceFolder}/STM32F103RE.svd",
            "servertype": "jlink",
            "serialNumber": "000772440170",
            "interface": "swd",
            "device": "STM32F103RE",
            "gdbPath": "arm-none-eabi-gdb",
            "runToMain": true,
            "runToEntryPoint": "main",
            "rttConfig": {
                "enabled": true,
                "address": "auto",
                "decoders": [
                    {
                        "label": "",
                        "port": 0,
                        "type": "console"
                    }
                ]
            },
            "rtos": "FreeRTOS",
            "showDevDebugOutput": "none"
        },
   ]
}